# =============================================================================
# REQUIRED SECRETS - Application will not start without these
# =============================================================================

# Database (REQUIRED)
DATABASE_URL=postgres://oppskrift:oppskrift@localhost:5432/oppskrift

# JWT Secret (REQUIRED - minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production-min-32-chars

# S3 Bucket (REQUIRED)
S3_BUCKET=oppskrift

# =============================================================================
# OPTIONAL - Have sensible defaults
# =============================================================================

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# Application
RUST_LOG=info,oppskrift=debug
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000

# Federation
INSTANCE_DOMAIN=localhost:3000
INSTANCE_NAME=Oppskrift Dev
