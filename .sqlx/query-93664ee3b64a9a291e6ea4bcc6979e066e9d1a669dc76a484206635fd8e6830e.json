{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                u.id as user_id,\n                u.username,\n                u.display_name,\n                u.avatar_url,\n                gm.added_at,\n                gm.added_by\n            FROM group_members gm\n            JOIN users u ON u.id = gm.user_id\n            WHERE gm.group_id = $1\n            ORDER BY gm.added_at\n            ",
