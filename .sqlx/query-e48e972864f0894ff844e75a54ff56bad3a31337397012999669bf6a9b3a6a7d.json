{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                bc.id, bc.book_id, bc.recipe_id, bc.contributor_id, bc.added_at,\n                u.display_name as contributor_display_name\n            FROM book_contributions bc\n            JOIN users u ON u.id = bc.contributor_id\n            WHERE bc.book_id = $1\n            ORDER BY bc.added_at DESC\n            ",
