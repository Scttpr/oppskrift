{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                c.id, c.recipe_id, c.author_id,\n                COALESCE(NULLIF(u.display_name, ''), u.username) as \"author_name!\",\n                c.body, c.created_at\n            FROM recipe_comments c\n            JOIN users u ON u.id = c.author_id\n            WHERE c.recipe_id = $1\n            ORDER BY c.created_at DESC\n            ",
