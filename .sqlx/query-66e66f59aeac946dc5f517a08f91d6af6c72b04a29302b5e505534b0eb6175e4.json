{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                b.id, b.owner_id, b.title, b.description, b.cover_image_url,\n                b.visibility as \"visibility: Visibility\",\n                b.created_at,\n                COUNT(e.id) as \"recipe_count!\"\n            FROM recipe_books b\n            LEFT JOIN book_recipe_entries e ON e.book_id = b.id\n            WHERE b.owner_id = $1\n            GROUP BY b.id\n            ORDER BY b.title\n            ",
