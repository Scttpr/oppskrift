  "query": "\n            UPDATE groups SET\n                name = COALESCE($2, name),\n                description = COALESCE($3, description),\n                updated_at = NOW()\n            WHERE id = $1\n            RETURNING id, owner_id, name, description, created_at, updated_at\n            ",
