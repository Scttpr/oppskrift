  "query": "\n            SELECT\n                id, actor_id,\n                activity_type as \"activity_type: ActivityType\",\n                target_type as \"target_type: TargetType\",\n                target_id, created_at, ap_id\n            FROM activities\n            WHERE actor_id = $1\n            ORDER BY created_at DESC\n            LIMIT $2 OFFSET $3\n            ",
