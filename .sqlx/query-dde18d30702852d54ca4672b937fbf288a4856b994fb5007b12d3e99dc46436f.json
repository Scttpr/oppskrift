{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                g.id, g.owner_id, g.name, g.description, g.created_at, g.updated_at,\n                COUNT(gm.user_id) as \"member_count!\"\n            FROM groups g\n            LEFT JOIN group_members gm ON gm.group_id = g.id\n            WHERE g.id = $1\n            GROUP BY g.id\n            ",
